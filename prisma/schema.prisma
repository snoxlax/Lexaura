// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Letter {
  id     String @id @default(cuid())
  userId String

  subject String?
  content String?
  mood    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("letters")
}
